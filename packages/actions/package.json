{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@discord.self/actions",
	"version": "0.1.0",
	"description": "A set of actions that we use for our workflows",
	"private": true,
	"scripts": {
		"test": "vitest run --config ../../vitest.config.ts",
		"build": "tsc --noEmit --lib ESNext,DOM && tsup",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src __tests__",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src __tests__",
		"fmt": "pnpm run format"
	},
	"type": "module",
	"directories": {
		"lib": "src",
		"test": "__tests__"
	},
	"files": [
		"dist"
	],
	"contributors": [
		"Crawl <icrawltogo@gmail.com>"
	],
	"license": "Apache-2.0",
	"keywords": [
		"api",
		"bot",
		"client",
		"node",
		"discordjs"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/actions"
	},
	"bugs": {
		"url": "https://github.com/marioparaschiv/discord.self/issues"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/github": "^9.0.0",
		"@actions/glob": "^0.6.1",
		"@aws-sdk/client-s3": "^3.1019.0",
		"@discord.self/scripts": "workspace:^",
		"commander": "^14.0.3",
		"meilisearch": "^0.56.0",
		"p-limit": "^7.3.0",
		"p-queue": "^9.1.0",
		"tslib": "^2.8.1",
		"undici": "7.24.6"
	},
	"devDependencies": {
		"@npm/types": "^2.1.0",
		"@types/bun": "^1.3.11",
		"@types/node": "^24.12.0",
		"@vitest/coverage-v8": "^4.1.2",
		"terser": "^5.46.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"vitest": "^4.1.2",
		"oxlint": "^1.59.0",
		"oxfmt": "^0.44.0"
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
