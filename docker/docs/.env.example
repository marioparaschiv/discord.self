# Copy to docker/docs/.env (or project root .env) and override for production.

# Optional image overrides
MINIO_IMAGE=minio/minio:latest
MEILI_IMAGE=getmeili/meilisearch:v1.15
BOOTSTRAP_IMAGE=node:24-bookworm

# Restart behavior
DOCS_RESTART_POLICY=unless-stopped

# Service port binding
WEBSITE_BIND_HOST=0.0.0.0
WEBSITE_PORT=3000
GUIDE_BIND_HOST=0.0.0.0
GUIDE_PORT=3001
MINIO_BIND_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_CONSOLE_BIND_HOST=127.0.0.1
MINIO_CONSOLE_PORT=9001
MEILI_BIND_HOST=127.0.0.1
MEILI_PORT=7700

# MinIO auth (change in production)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# Meilisearch auth (change in production)
MEILI_MASTER_KEY=change-me
MEILI_NO_ANALYTICS=true
MEILI_HTTP_ADDR=0.0.0.0:7700
MEILI_HTTP_CORS_ORIGIN=http://localhost:3000

# Bootstrap storage + search wiring
BOOTSTRAP_FORCE_INSTALL=true
BOOTSTRAP_FORCE_ACTIONS_BUILD=true
DOCS_STORAGE_ENDPOINT=http://minio:9000
DOCS_STORAGE_ACCESS_KEY_ID=minioadmin
DOCS_STORAGE_SECRET_ACCESS_KEY=change-me
DOCS_STORAGE_BUCKET=docs
DOCS_STORAGE_BUCKET_URL=http://minio:9000/docs

READMES_STORAGE_ENDPOINT=http://minio:9000
READMES_STORAGE_ACCESS_KEY_ID=minioadmin
READMES_STORAGE_SECRET_ACCESS_KEY=change-me
READMES_STORAGE_BUCKET=docs

SEARCH_API_URL=http://meilisearch:7700
SEARCH_API_KEY=change-me
S3_FORCE_PATH_STYLE=true

# Website runtime + build-time search config
# Note: changing NEXT_PUBLIC_* requires rebuilding website image.
NEXT_PUBLIC_SEARCH_API_URL=http://localhost:7700
NEXT_PUBLIC_SEARCH_API_KEY=change-me
READMES_STORAGE_BUCKET_URL=http://minio:9000/docs
GUIDE_REDIRECT_URL=http://localhost:3001
