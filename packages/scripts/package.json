{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@discord.self/scripts",
	"version": "0.1.0",
	"description": "A set of scripts that we use for our workflows",
	"private": true,
	"scripts": {
		"build": "tsc --noEmit --lib ESNext,DOM && tsup",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src turbo/generators/config.ts",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src turbo/generators/config.ts",
		"fmt": "pnpm run format"
	},
	"bin": {
		"generate-split-documentation": "./bin/generateSplitDocumentation.js",
		"sort-labels": "./bin/sortLabels.js"
	},
	"exports": {
		".": {
			"require": {
				"types": "./dist/src/index.d.ts",
				"default": "./dist/src/index.js"
			},
			"import": {
				"types": "./dist/src/index.d.mts",
				"default": "./dist/src/index.mjs"
			}
		}
	},
	"main": "./dist/src/index.js",
	"module": "./dist/src/index.mjs",
	"types": "./dist/src/index.d.ts",
	"directories": {
		"bin": "bin",
		"lib": "src",
		"example": "turbo"
	},
	"files": [
		"bin/generateSplitDocumentation.js",
		"dist"
	],
	"contributors": [
		"Crawl <icrawltogo@gmail.com>"
	],
	"license": "Apache-2.0",
	"keywords": [
		"api",
		"bot",
		"client",
		"node",
		"discordjs"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/scripts"
	},
	"bugs": {
		"url": "https://github.com/marioparaschiv/discord.self/issues"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"dependencies": {
		"@discord.self/api-extractor-model": "workspace:^",
		"@discord.self/api-extractor-utils": "workspace:^",
		"@microsoft/tsdoc": "~0.15.1",
		"@microsoft/tsdoc-config": "~0.17.1",
		"commander": "^14.0.3",
		"tslib": "^2.8.1",
		"undici": "7.24.6",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@turbo/gen": "^2.8.21",
		"@types/node": "^24.12.0",
		"terser": "^5.46.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"oxlint": "^1.59.0",
		"oxfmt": "^0.44.0"
	},
	"engines": {
		"node": ">=22.12.0"
	}
}
