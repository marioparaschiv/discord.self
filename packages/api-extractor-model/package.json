{
	"name": "@discord.self/api-extractor-model",
	"version": "7.30.6",
	"description": "A helper library for loading and saving the .api.json files created by API Extractor",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/api-extractor-model"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"license": "MIT",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src"
	},
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"dependencies": {
		"@microsoft/tsdoc": "~0.15.1",
		"@microsoft/tsdoc-config": "~0.17.1",
		"@rushstack/node-core-library": "5.13.1"
	},
	"devDependencies": {
		"@types/node": "^24.12.0",
		"terser": "^5.46.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"oxlint": "^1.59.0",
		"oxfmt": "^0.44.0"
	}
}
