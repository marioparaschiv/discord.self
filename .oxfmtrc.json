{
	"printWidth": 120,
	"useTabs": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"endOfLine": "lf",
	"sortPackageJson": false,
	"ignorePatterns": [
		"CODEOWNERS",
		"CHANGELOG.md",
		"**/*.api.json",
		"tsup.config.bundled*",
		"vitest.config.ts.timestamp*",
		"pnpm-lock.yaml"
	]
}
