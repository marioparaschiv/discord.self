{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@discord.self/voice",
	"version": "0.19.2",
	"description": "Implementation of the Discord Voice API for Node.js",
	"scripts": {
		"build": "tsc --noEmit && tsup && node scripts/postbuild.mjs",
		"build:docs": "tsc -p tsconfig.docs.json",
		"test": "vitest run --config ../../vitest.config.ts",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src __tests__",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src __tests__",
		"fmt": "pnpm run format",
		"docs": "pnpm run build:docs && api-extractor run --local --minify && generate-split-documentation",
		"prepack": "pnpm run lint && pnpm run test && pnpm run build",
		"changelog": "git cliff --prepend ./CHANGELOG.md -u -c ./cliff.toml -r ../../ --include-path 'packages/voice/*'",
		"release": "cliff-jumper"
	},
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"directories": {
		"lib": "src",
		"test": "__tests__"
	},
	"files": [
		"dist"
	],
	"contributors": [
		"Crawl <icrawltogo@gmail.com>",
		"Amish Shah <amishshah.2k@gmail.com>",
		"SpaceEEC <spaceeec@yahoo.com>",
		"Vlad Frangu <me@vladfrangu.dev>",
		"Aura Román <kyradiscord@gmail.com>"
	],
	"license": "Apache-2.0",
	"keywords": [
		"discord",
		"discord.js",
		"audio",
		"voice",
		"streaming"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/voice"
	},
	"bugs": {
		"url": "https://github.com/marioparaschiv/discord.self/issues"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"dependencies": {
		"@snazzah/davey": "^0.1.11",
		"@types/ws": "^8.18.1",
		"discord-api-types": "^0.38.43",
		"prism-media": "^1.3.5",
		"tslib": "^2.8.1",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@discord.self/api-extractor": "workspace:^",
		"@discordjs/opus": "^0.10.0",
		"@discord.self/scripts": "workspace:^",
		"@favware/cliff-jumper": "^6.0.0",
		"@noble/ciphers": "^2.1.1",
		"@types/node": "^22.19.15",
		"@vitest/coverage-v8": "^4.1.2",
		"esbuild-plugin-version-injector": "^1.2.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"vitest": "^4.1.2",
		"vitest-websocket-mock": "^0.5.0",
		"oxlint": "^1.59.0",
		"oxfmt": "^0.44.0"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
