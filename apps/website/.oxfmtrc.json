{
	"printWidth": 120,
	"useTabs": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"endOfLine": "lf",
	"sortTailwindcss": {
		"functions": ["cva", "cx"]
	},
	"sortPackageJson": false,
	"ignorePatterns": [
		".next",
		".turbo",
		".vscode",
		"coverage",
		"public/searchIndex",
		"src/assets/readme",
		"src/styles/unocss.css",
		"next-env.d.ts",
		"src/util/shiki.bundle.ts"
	]
}
