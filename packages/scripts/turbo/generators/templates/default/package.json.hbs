{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@discord.self/{{name}}",
	"version": "0.1.0",
	"description": "{{description}}",
	"scripts": {
		"build": "tsc --noEmit && tsup",
		"build:docs": "tsc -p tsconfig.docs.json",
		"test": "vitest run --config ../../vitest.config.ts",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src",
		"fmt": "pnpm run format",
		"docs": "pnpm run build:docs && api-extractor run --local",
		"prepack": "pnpm run build && pnpm run lint",
		"changelog": "git cliff --prepend ./CHANGELOG.md -u -c ./cliff.toml -r ../../ --include-path 'packages/{{name}}/*'",
		"release": "cliff-jumper"
	},
	"exports": {
		".": {
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"directories": {
		"lib": "src",
		"test": "__tests__"
	},
	"files": [
		"dist"
	],
	"contributors": [
		"Crawl <icrawltogo@gmail.com>",
		"SpaceEEC <spaceeec@yahoo.com>",
		"Vlad Frangu <me@vladfrangu.dev>",
		"Aura Román <kyradiscord@gmail.com>"
	],
	"license": "Apache-2.0",
	"keywords": [],
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/{{name}}"
	},
	"bugs": {
		"url": "https://github.com/marioparaschiv/discord.self/issues"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"dependencies": {},
	"devDependencies": {
		"@discord.self/api-extractor": "workspace:^",
		"@favware/cliff-jumper": "^6.0.0",
		"@types/node": "^24.12.0",
		"@vitest/coverage-v8": "^4.1.2",
		"esbuild-plugin-version-injector": "^1.2.1",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
