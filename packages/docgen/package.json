{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@discord.self/docgen",
	"version": "0.12.1",
	"description": "The docs.json generator for discord.js and its related projects",
	"private": true,
	"scripts": {
		"build": "tsup",
		"lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish src",
		"format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish src",
		"fmt": "pnpm run format",
		"prepack": "pnpm run format && pnpm run build"
	},
	"bin": "./bin/index.js",
	"exports": {
		".": {
			"require": {
				"types": "./dist/src/index.d.ts",
				"default": "./dist/src/index.js"
			},
			"import": {
				"types": "./dist/src/index.d.mts",
				"default": "./dist/src/index.mjs"
			}
		}
	},
	"main": "./dist/src/index.js",
	"module": "./dist/src/index.mjs",
	"types": "./dist/src/index.d.ts",
	"directories": {
		"bin": "bin",
		"lib": "src"
	},
	"files": [
		"bin/index.js",
		"dist"
	],
	"contributors": [
		"Mario P. <me@marioparaschiv.com>",
		"Crawl <icrawltogo@gmail.com>",
		"Amish Shah <amishshah.2k@gmail.com>",
		"Schuyler Cebulskie <Gawdl3y@Gawdl3y.com>"
	],
	"license": "Apache-2.0",
	"keywords": [
		"documentation",
		"docs",
		"generator",
		"docgen",
		"docsgen",
		"node",
		"discordjs"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/marioparaschiv/discord.self.git",
		"directory": "packages/docgen"
	},
	"bugs": {
		"url": "https://github.com/marioparaschiv/discord.self/issues"
	},
	"homepage": "https://discord.js.org",
	"funding": "https://github.com/marioparaschiv/discord.self?sponsor",
	"dependencies": {
		"commander": "^14.0.3",
		"jsdoc-to-markdown": "^8.0.3",
		"tslib": "^2.8.1",
		"typedoc": "^0.25.13"
	},
	"devDependencies": {
		"@types/jsdoc-to-markdown": "^7.0.6",
		"@types/node": "^24.12.0",
		"terser": "^5.46.1",
		"tsup": "^8.5.1",
		"turbo": "^2.8.21",
		"typescript": "~5.9.3",
		"oxlint": "^1.59.0",
		"oxfmt": "^0.44.0"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
