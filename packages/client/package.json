{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@discord.self/client",
  "version": "14.16.3",
  "description": "A patched discord.js client focused on user-account sessions",
  "scripts": {
    "test": "pnpm run docs:test && pnpm run test:typescript",
    "test:typescript": "tsc --noEmit && tsd",
    "lint": "oxfmt --check . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --format=stylish scripts src typings",
    "format": "oxfmt . && oxlint --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --jsdoc-plugin --vitest-plugin --promise-plugin --node-plugin --fix --format=stylish scripts src typings",
    "fmt": "pnpm run format",
    "docs": "docgen -i \"./src/*.js\" \"./src/**/*.js\" -c ./docs/index.json -r ../../ -o ./docs/docs.json && pnpm run docs:new",
    "docs:test": "docgen -i \"./src/*.js\" \"./src/**/*.js\" -c ./docs/index.json -r ../../",
    "docs:new": "api-extractor run --local --minify && generate-split-documentation",
    "prepack": "pnpm run lint && pnpm run test && node ./scripts/esmDts.mjs",
    "changelog": "git cliff --prepend ./CHANGELOG.md -u -c ./cliff.toml -r ../../ --include-path 'packages/client/*'",
    "release": "cliff-jumper"
  },
  "main": "./src/index.js",
  "types": "./typings/index.d.ts",
  "exports": {
    ".": {
      "types": "./typings/index.d.ts",
      "import": {
        "types": "./typings/index.d.mts",
        "default": "./src/index.js"
      },
      "require": {
        "types": "./typings/index.d.ts",
        "default": "./src/index.js"
      }
    }
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "files": [
    "src",
    "typings/*.d.ts",
    "typings/*.d.mts"
  ],
  "contributors": [
    "Mario P. <me@marioparaschiv.com>",
    "Crawl <icrawltogo@gmail.com>",
    "Amish Shah <amishshah.2k@gmail.com>",
    "Vlad Frangu <me@vladfrangu.dev>",
    "SpaceEEC <spaceeec@yahoo.com>",
    "Aura Román <kyradiscord@gmail.com>"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "discord",
    "api",
    "client",
    "node",
    "discordapp",
    "selfbot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marioparaschiv/discord.self.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/marioparaschiv/discord.self/issues"
  },
  "homepage": "https://github.com/marioparaschiv/discord.self",
  "dependencies": {
    "@discord.self/collection": "workspace:^",
    "@discord.self/formatters": "workspace:^",
    "@discord.self/rest": "workspace:^",
    "@discord.self/util": "workspace:^",
    "@discord.self/ws": "workspace:^",
    "@sapphire/snowflake": "3.5.5",
    "@vladfrangu/async_event_emitter": "^2.4.7",
    "discord-api-types": "^0.38.43",
    "fast-deep-equal": "3.1.3",
    "lodash.snakecase": "4.1.1",
    "magic-bytes.js": "^1.13.0",
    "tslib": "^2.8.1",
    "undici": "7.24.6"
  },
  "devDependencies": {
    "@discord.self/api-extractor": "workspace:^",
    "@discord.self/docgen": "workspace:^",
    "@discord.self/scripts": "workspace:^",
    "@favware/cliff-jumper": "^6.0.0",
    "@types/node": "^22.19.15",
    "tsd": "^0.33.0",
    "turbo": "^2.8.21",
    "typescript": "~5.9.3",
    "oxlint": "^1.59.0",
    "oxfmt": "^0.44.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "provenance": true
  }
}
